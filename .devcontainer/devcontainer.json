{
  "name": "IAmDataEng — rest-api-ingestion",
  "image": "mcr.microsoft.com/devcontainers/python:3.11-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "forwardPorts": [8765],
  "portsAttributes": {
    "8765": {
      "label": "Laneway mock API",
      "onAutoForward": "silent"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["tests"]
      }
    }
  },
  "postCreateCommand": "pip install --upgrade pip && pip install -r requirements.txt && cp -n .env.example .env || true",
  "remoteUser": "vscode"
}
