# IAmDataEng — rest-api-ingestion
#
# Copy this file to `.env` (NEVER commit `.env`) and adjust the values for your
# local setup. In Codespaces, the devcontainer creates `.env` for you with the
# defaults below already set.

# Base URL of the Laneway mock API.
# - In the devcontainer / docker-compose:  http://laneway-mock:8080
# - In CI / local in-process server:       http://127.0.0.1:8765
LANEWAY_BASE_URL=http://127.0.0.1:8765

# Fake API key. The mock server accepts any non-empty value.
# Real-world: would be a 40-char token issued by Laneway. Don't ship real
# secrets in a public repo — the CI rubric checks for this.
LANEWAY_API_KEY=replace-me-with-any-non-empty-string

# Ingestion date used by `python -m src.ingest.laneway` when no CLI flag is
# given. ISO-8601 short form (YYYY-MM-DD).
INGEST_DATE=2026-04-10
